    useEffect(() => {
        if (!isDragging) return
        const timer = setInterval(() => {
            const idleMs = Date.now() - (lastDragActivityAt.current || 0)
            if (idleMs > 450) {
                dragCounter.current = 0
                setIsDragging(false)
                setExternalDropFolderId(null)
                document.body.classList.remove('dragging-file')
                internalDraggedMediaIdsRef.current = []
                isInternalDrag.current = false
            }
        }, 120)
        return () => clearInterval(timer)
    }, [isDragging])

    useEffect(() => {
        const handleTriggerImport = (_: any, filePaths: string[], options?: { deleteSource?: boolean; importSource?: string }) => {
            console.log('[App] Received trigger-import:', filePaths)
            const dropZone = externalDropZoneRef.current
            const internalDraggedMediaIds = internalDraggedMediaIdsRef.current

            if (isInternalDrag.current && dropZone?.kind === 'folder' && internalDraggedMediaIds.length > 0) {
                handleFolderDrop(dropZone.folderId, null, internalDraggedMediaIds).catch((e) => {
                    console.error('Internal media folder drop failed:', e)
                })
                internalDraggedMediaIdsRef.current = []
                isInternalDrag.current = false
                return
            }
