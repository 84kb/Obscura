{
    "name": "obscura",
    "version": "0.8.13",
    "description": "ライブラリ型メディアプレイヤー",
    "main": "dist-tauri/index.html",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run tauri:dev",
        "bump": "node scripts/bump-version.js",
        "build": "npm run tauri:build",
        "preview": "vite preview",
        "dev:web": "vite",
        "predev:tauri:web": "node scripts/free-port.cjs 1420",
        "dev:tauri:web": "vite --config vite.tauri.config.ts",
        "build:tauri:web": "vite build --config vite.tauri.config.ts",
        "pretauri:dev": "node scripts/kill-obscura-dev.cjs",
        "prepare:tauri:node": "node scripts/prepare-tauri-node.cjs",
        "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
        "tauri:build": "npm run bump && npm run prepare:tauri:node && tauri build && node scripts/generate-latest-yml.cjs",
        "build:mobile": "npm run bump && vite build --config vite.mobile.config.ts && move dist-mobile\\mobile.html dist-mobile\\index.html && npx cap sync android"
    },
    "keywords": [
        "media",
        "player",
        "library",
        "tauri"
    ],
    "author": "84kb",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/84kb/Obscura.git"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.0.0",
        "@types/chokidar": "^1.7.5",
        "@types/cors": "^2.8.19",
        "@types/discord-rpc": "^4.0.10",
        "@types/express": "^5.0.6",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^20.10.6",
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-basic-ssl": "^1.1.0",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.2",
        "ffmpeg-static": "^5.3.0",
        "ffprobe-static": "^3.1.0",
        "local-ssl-proxy": "^2.0.5",
        "selfsigned": "^5.5.0",
        "typescript": "^5.3.3",
        "vite": "^5.2.0",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "@capacitor/android": "^8.0.2",
        "@capacitor/cli": "^8.0.2",
        "@capacitor/core": "^8.0.2",
        "@capacitor/filesystem": "^8.1.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@emotion/is-prop-valid": "^1.4.0",
        "@tauri-apps/api": "^2.0.0",
        "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
        "@tauri-apps/plugin-dialog": "^2.0.0",
        "@tauri-apps/plugin-notification": "^2.0.0",
        "@tauri-apps/plugin-opener": "^2.0.0",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/multer": "^2.0.0",
        "@xpadev-net/niconicomments": "^0.2.76",
        "7zip-bin": "^5.2.0",
        "chokidar": "^3.6.0",
        "cors": "^2.8.5",
        "discord-rpc": "^4.0.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "fluent-ffmpeg": "^2.1.3",
        "framer-motion": "^12.29.3",
        "fs-extra": "^11.3.3",
        "helmet": "^8.1.0",
        "idb": "^8.0.3",
        "lucide-react": "^0.563.0",
        "multer": "^2.0.2",
        "nanoid": "^3.3.11",
        "node-machine-id": "^1.1.12",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-virtuoso": "^4.18.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "virtua": "^0.48.3"
    }
}
